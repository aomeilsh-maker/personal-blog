---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
	url: postUrl,
	inLanguage: 'zh-CN',
	keywords: tags?.join(', '),
};
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
		<style>
			main {
				width: min(980px, calc(100% - 1rem));
			}
			.back {
				display: inline-block;
				font-size: 0.9rem;
				color: rgb(var(--gray));
				text-decoration: none;
				margin-bottom: 0.6rem;
			}
			.hero-image {
				margin-bottom: 1rem;
			}
			.hero-image img {
				display: block;
				width: 100%;
				margin: 0 auto;
				border-radius: 14px;
			}
			.prose {
				max-width: 760px;
				margin: auto;
				padding: 0.2rem 0.4rem 0.6rem;
			}
			.title {
				margin-bottom: 1rem;
				padding-bottom: 0.9rem;
				border-bottom: 1px solid rgba(var(--gray), 0.22);
			}
			.title h1 {
				margin: 0.3rem 0 0;
				line-height: 1.35;
			}
			.date {
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.84rem;
			}
			.tax {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-top: 0.6rem;
			}
			.chip {
				display: inline-flex;
				align-items: center;
				padding: 0.2rem 0.55rem;
				border-radius: 999px;
				background: rgba(var(--accent-rgb), 0.12);
				color: var(--accent);
				font-size: 0.78rem;
			}
			.prose :global(p) {
				margin: 1rem 0;
				line-height: 1.9;
			}
			.prose :global(h2) {
				margin-top: 1.7rem;
				font-size: 1.45rem;
			}
			.prose :global(h3) {
				margin-top: 1.3rem;
				font-size: 1.2rem;
			}
			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.35rem;
			}
			.prose :global(li) {
				margin: 0.35rem 0;
			}
			.prose :global(table) {
				width: 100%;
				border-collapse: collapse;
				margin: 1rem 0;
				font-size: 0.92rem;
			}
			.prose :global(th),
			.prose :global(td) {
				border: 1px solid rgba(var(--gray), 0.24);
				padding: 0.5rem 0.55rem;
				text-align: left;
			}
			.prose :global(th) {
				background: rgba(var(--gray), 0.08);
			}
			.prose :global(blockquote) {
				font-size: 1rem;
				color: rgb(var(--gray));
				background: rgba(var(--accent-rgb), 0.05);
				border-radius: 10px;
				padding: 0.7rem 0.9rem;
				border-left: 3px solid var(--accent);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<a class="back" href={`${base}blog`}>← 返回文章列表</a>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										最后更新于 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{(category || (tags && tags.length)) && (
							<div class="tax">
								{category && <span class="chip">分类：{category}</span>}
								{tags?.map((t) => <span class="chip">#{t}</span>)}
							</div>
						)}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
