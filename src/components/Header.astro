---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<header>
	<nav>
		<h2><a href={base}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={base}>首页</HeaderLink>
			<HeaderLink href={`${base}blog`}>文章</HeaderLink>
			<HeaderLink href={`${base}categories`}>分类</HeaderLink>
			<HeaderLink href={`${base}about`}>关于</HeaderLink>
			<a class="github-link" href="https://github.com/aomeilsh-maker" target="_blank" rel="noreferrer">GitHub</a>
		</div>
		<div class="actions">
			<form class="search" action={`${base}blog`} method="get" role="search">
				<label class="sr-only" for="nav-search">搜索文章</label>
				<input id="nav-search" name="q" type="search" placeholder="搜索文章" />
				<button type="submit" aria-label="确认搜索">确认</button>
			</form>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 30;
		padding: 0.2rem 1rem;
		background: rgba(255, 255, 255, 0.86);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray), 0.18);
	}
	h2 {
		margin: 0;
		font-size: 1.05rem;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		height: 56px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1040px;
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
	}
	nav a {
		padding: 0.55rem 0.8rem;
		color: rgb(var(--black));
		border-radius: 10px;
		text-decoration: none;
		font-size: 0.95rem;
	}
	nav a.active {
		background: rgba(var(--accent-rgb), 0.12);
		color: var(--accent);
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 0.45rem;
	}
	.search {
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
	}
	.search input {
		width: 180px;
		padding: 0.45rem 0.65rem;
		border-radius: 10px;
		border: 1px solid rgba(var(--gray), 0.3);
		font-size: 0.86rem;
		background: rgba(255, 255, 255, 0.9);
		color: rgb(var(--black));
	}
	.search input:focus {
		outline: none;
		border-color: rgba(var(--accent-rgb), 0.62);
		box-shadow: 0 0 0 3px rgba(var(--accent-rgb), 0.16);
	}
	.search button {
		padding: 0.45rem 0.65rem;
		border-radius: 10px;
		border: 1px solid rgba(var(--gray), 0.35);
		background: #fff;
		color: rgb(23, 26, 34);
		font-size: 0.84rem;
		font-weight: 700;
		cursor: pointer;
	}
	.github-link {
		font-size: 0.9rem;
		padding: 0.5rem 0.75rem;
		border: 1px solid rgba(var(--gray), 0.28);
		border-radius: 10px;
	}
	@media (max-width: 900px) {
		.search input {
			width: 140px;
		}
	}
	@media (max-width: 720px) {
		nav {
			height: auto;
			padding: 0.55rem 0;
			gap: 0.45rem;
			flex-wrap: wrap;
		}
		.actions {
			width: 100%;
			justify-content: space-between;
		}
		.search {
			flex: 1;
		}
		.search input {
			width: 100%;
		}
	}
</style>
