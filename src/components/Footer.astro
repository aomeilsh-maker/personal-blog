---
const today = new Date();
---

<footer>
	<div class="inner">
		<p>© {today.getFullYear()} Aomei · 写作是为了更清楚地思考。</p>
		<p class="sub">Powered by Astro · Deployed on GitHub Pages</p>
	</div>
</footer>
<style>
	footer {
		margin-top: 3rem;
		padding: 2rem 1rem 3rem;
	}
	.inner {
		max-width: 1040px;
		margin: 0 auto;
		border-top: 1px solid rgba(var(--gray), 0.22);
		padding-top: 1.25rem;
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.92rem;
	}
	.sub {
		margin-top: 0.2rem;
		font-size: 0.85rem;
		opacity: 0.85;
	}
</style>
