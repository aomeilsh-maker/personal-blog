---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const categoryCount = posts.reduce(
	(acc, p) => {
		const key = p.data.category || '未分类';
		acc[key] = (acc[key] || 0) + 1;
		return acc;
	},
	{} as Record<string, number>,
);
const sortedCategories = Object.entries(categoryCount).sort((a, b) => b[1] - a[1]);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main { width: min(1040px, calc(100% - 1rem)); }
			.head { display:flex; justify-content:space-between; align-items:end; gap:1rem; margin-bottom: 1rem; }
			.hint { font-size:0.9rem; color: rgb(var(--gray)); }
			.cats { display:flex; flex-wrap:wrap; gap:0.45rem; margin-bottom:1rem; }
			.cat {
				display:inline-flex; gap:0.35rem; align-items:center;
				padding:0.32rem 0.62rem; border-radius:999px;
				background: rgba(var(--accent-rgb), .1); color: var(--accent);
				font-size:0.82rem; text-decoration:none;
			}
			.list { display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:0.85rem; }
			.item {
				display:block; padding:1rem 1rem .95rem;
				border:1px solid rgba(var(--gray),.18); border-radius:14px;
				text-decoration:none; background:linear-gradient(180deg,#fff 0%,#fcfcff 100%);
				transition:.18s ease;
			}
			.item:hover { transform: translateY(-2px); box-shadow:0 12px 24px rgba(17,24,39,.08); border-color: rgba(var(--accent-rgb), .45); }
			.topline { display:flex; justify-content:space-between; gap:.5rem; margin-bottom:.5rem; }
			.badge { font-size:.74rem; color:var(--accent); background: rgba(var(--accent-rgb), .12); padding:.2rem .5rem; border-radius:999px; }
			.meta { font-size:.84rem; color: rgb(var(--gray)); }
			.title { margin:0 0 .35rem; color: rgb(var(--black)); font-size:1.08rem; line-height:1.45; }
			.excerpt { margin:0 0 .65rem; font-size:.92rem; color: rgb(var(--gray-dark)); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
			@media (max-width:820px){ .list{ grid-template-columns:1fr; } }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="head">
				<h1>文章</h1>
				<p class="hint">共 {posts.length} 篇</p>
			</div>
			<div class="cats">
				{sortedCategories.map(([name, count]) => <a class="cat" href={`${base}categories#${encodeURIComponent(name)}`}>{name}<span>{count}</span></a>)}
			</div>
			<div class="list">
				{posts.map((post) => (
					<a class="item" href={`${base}blog/${post.id}/`}>
						<div class="topline">
							<span class="badge">{post.data.category || '未分类'}</span>
							<p class="meta"><FormattedDate date={post.data.pubDate} /></p>
						</div>
						<h2 class="title">{post.data.title}</h2>
						<p class="excerpt">{post.data.description || '阅读这篇文章'}</p>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
