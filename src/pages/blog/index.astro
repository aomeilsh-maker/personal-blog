---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Cover1 from '../../assets/blog-placeholder-1.jpg';
import Cover2 from '../../assets/blog-placeholder-2.jpg';
import Cover3 from '../../assets/blog-placeholder-3.jpg';
import Cover4 from '../../assets/blog-placeholder-4.jpg';
import Cover5 from '../../assets/blog-placeholder-5.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const fixedCategories = ['日语学习', 'AI学习', '杂文'];
const categoryCount = posts.reduce(
	(acc, p) => {
		const key = fixedCategories.includes(p.data.category || '') ? (p.data.category as string) : '杂文';
		acc[key] = (acc[key] || 0) + 1;
		return acc;
	},
	Object.fromEntries(fixedCategories.map((k) => [k, 0])) as Record<string, number>,
);
const sortedCategories = fixedCategories.map((k) => [k, categoryCount[k]] as const);

const coverPool = [Cover1, Cover2, Cover3, Cover4, Cover5];
const categoryCoverPool: Record<string, any[]> = {
	日语学习: [Cover1, Cover2],
	AI学习: [Cover3, Cover4],
	杂文: [Cover5, Cover4, Cover2],
};
const categoryTheme: Record<string, { bg: string; text: string; border: string }> = {
	日语学习: { bg: 'rgba(76, 132, 255, .18)', text: '#dce7ff', border: 'rgba(180,206,255,.55)' },
	AI学习: { bg: 'rgba(126, 92, 255, .2)', text: '#e8deff', border: 'rgba(210,193,255,.55)' },
	杂文: { bg: 'rgba(11, 201, 162, .2)', text: '#dbfff5', border: 'rgba(166,255,228,.55)' },
};

function hashId(id: string) {
	let h = 0;
	for (let i = 0; i < id.length; i++) h = (h * 31 + id.charCodeAt(i)) >>> 0;
	return h;
}

function pickCover(post: (typeof posts)[number]) {
	if (post.data.heroImage) return post.data.heroImage;
	const cat = post.data.category || '杂文';
	const pool = categoryCoverPool[cat] || coverPool;
	return pool[hashId(post.id) % pool.length];
}

function pickTheme(category?: string) {
	return categoryTheme[category || '杂文'] || categoryTheme['杂文'];
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main { width: min(1120px, calc(100% - 1rem)); }
			.head { display:flex; justify-content:space-between; align-items:end; gap:1rem; margin-bottom:1rem; }
			.hint { font-size:0.9rem; color: rgb(var(--gray)); }
			.cats { display:flex; flex-wrap:wrap; gap:0.55rem; margin-bottom:1.2rem; }
			.cat {
				display:inline-flex; gap:0.38rem; align-items:center;
				padding:0.4rem 0.7rem; border-radius:999px;
				background: linear-gradient(180deg, rgba(var(--accent-rgb), .18), rgba(var(--accent-rgb), .08));
				color: var(--accent); font-size:0.83rem; text-decoration:none;
				border: 1px solid rgba(var(--accent-rgb), .25);
			}
			.list { display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:1rem; }
			.item {
				display:block; overflow:hidden;
				border:1px solid rgba(var(--gray),.18); border-radius:16px;
				text-decoration:none; background:linear-gradient(180deg,#fff 0%,#fcfcff 100%);
				transition:.22s ease;
			}
			.item:hover { transform: translateY(-4px); box-shadow:0 16px 30px rgba(17,24,39,.12); border-color: rgba(var(--accent-rgb), .45); }
			.cover { position: relative; height: 180px; overflow: hidden; }
			.cover :global(img) { width:100%; height:100%; object-fit: cover; transform: scale(1.03); }
			.overlay {
				position:absolute; inset:0;
				background: linear-gradient(to top, rgba(8,10,20,.62), rgba(8,10,20,.08));
				display:flex; align-items:flex-end; justify-content:space-between; padding:0.75rem;
			}
			.badge {
				font-size:.74rem; color:#fff; background: rgba(255,255,255,.2);
				backdrop-filter: blur(4px); padding:.22rem .55rem; border-radius:999px;
				border:1px solid rgba(255,255,255,.32);
			}
			.content { padding: .85rem .95rem 1rem; }
			.topline { display:flex; justify-content:flex-end; gap:.5rem; margin-bottom:.35rem; }
			.meta { font-size:.84rem; color: rgb(var(--gray)); }
			.title { margin:0 0 .35rem; color: rgb(var(--black)); font-size:1.08rem; line-height:1.45; }
			.excerpt { margin:0; font-size:.92rem; color: rgb(var(--gray-dark)); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
			@media (max-width:820px){ .list{ grid-template-columns:1fr; } .cover{height:160px;} }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="head">
				<h1>文章</h1>
				<p class="hint">共 {posts.length} 篇</p>
			</div>
			<div class="cats">
				{sortedCategories.map(([name, count]) => <a class="cat" href={`${base}categories#${encodeURIComponent(name)}`}>{name}<span>{count}</span></a>)}
			</div>
			<div class="list">
				{posts.map((post) => {
					const cat = post.data.category || '杂文';
					const cover = pickCover(post);
					const theme = pickTheme(cat);
					return (
						<a class="item" href={`${base}blog/${post.id}/`}>
							<div class="cover">
								<Image src={cover} alt={post.data.title} width={960} height={540} />
								<div class="overlay">
									<span class="badge" style={`background:${theme.bg};color:${theme.text};border-color:${theme.border}`}>{cat}</span>
								</div>
							</div>
							<div class="content">
								<div class="topline">
									<p class="meta"><FormattedDate date={post.data.pubDate} /></p>
								</div>
								<h2 class="title">{post.data.title}</h2>
								<p class="excerpt">{post.data.description || '阅读这篇文章'}</p>
							</div>
						</a>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>
