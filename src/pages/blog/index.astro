---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import CoverJP from '../../assets/blog-placeholder-1.jpg';
import CoverAI from '../../assets/blog-placeholder-3.jpg';
import CoverEssay from '../../assets/blog-placeholder-5.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const fixedCategories = ['日语学习', 'AI学习', '杂文'];
const categoryCount = posts.reduce(
	(acc, p) => {
		const key = fixedCategories.includes(p.data.category || '') ? (p.data.category as string) : '杂文';
		acc[key] = (acc[key] || 0) + 1;
		return acc;
	},
	Object.fromEntries(fixedCategories.map((k) => [k, 0])) as Record<string, number>,
);
const sortedCategories = fixedCategories.map((k) => [k, categoryCount[k]] as const);
const categoryCover: Record<string, any> = {
	日语学习: CoverJP,
	AI学习: CoverAI,
	杂文: CoverEssay,
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main { width: min(1120px, calc(100% - 1rem)); }
			.head { display:flex; justify-content:space-between; align-items:end; gap:1rem; margin-bottom: 1rem; }
			.hint { font-size:0.9rem; color: rgb(var(--gray)); }
			.cats { display:flex; flex-wrap:wrap; gap:0.55rem; margin-bottom:1.2rem; }
			.cat {
				display:inline-flex; gap:0.38rem; align-items:center;
				padding:0.4rem 0.7rem; border-radius:999px;
				background: linear-gradient(180deg, rgba(var(--accent-rgb), .18), rgba(var(--accent-rgb), .08));
				color: var(--accent); font-size:0.83rem; text-decoration:none;
				border: 1px solid rgba(var(--accent-rgb), .25);
			}
			.list { display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:1rem; }
			.item {
				display:block; overflow:hidden;
				border:1px solid rgba(var(--gray),.18); border-radius:16px;
				text-decoration:none; background:linear-gradient(180deg,#fff 0%,#fcfcff 100%);
				transition:.22s ease;
			}
			.item:hover { transform: translateY(-4px); box-shadow:0 16px 30px rgba(17,24,39,.12); border-color: rgba(var(--accent-rgb), .45); }
			.cover { position: relative; height: 168px; overflow: hidden; }
			.cover :global(img) { width:100%; height:100%; object-fit: cover; transform: scale(1.02); }
			.overlay {
				position:absolute; inset:0;
				background: linear-gradient(to top, rgba(8,10,20,.55), rgba(8,10,20,.08));
				display:flex; align-items:flex-end; padding:0.75rem;
			}
			.badge { font-size:.74rem; color:#fff; background: rgba(255,255,255,.2); backdrop-filter: blur(4px); padding:.22rem .55rem; border-radius:999px; }
			.content { padding: .85rem .95rem 1rem; }
			.topline { display:flex; justify-content:flex-end; gap:.5rem; margin-bottom:.35rem; }
			.meta { font-size:.84rem; color: rgb(var(--gray)); }
			.title { margin:0 0 .35rem; color: rgb(var(--black)); font-size:1.08rem; line-height:1.45; }
			.excerpt { margin:0; font-size:.92rem; color: rgb(var(--gray-dark)); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
			@media (max-width:820px){ .list{ grid-template-columns:1fr; } .cover{height:154px;} }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="head">
				<h1>文章</h1>
				<p class="hint">共 {posts.length} 篇</p>
			</div>
			<div class="cats">
				{sortedCategories.map(([name, count]) => <a class="cat" href={`${base}categories#${encodeURIComponent(name)}`}>{name}<span>{count}</span></a>)}
			</div>
			<div class="list">
				{posts.map((post) => {
					const cat = post.data.category || '杂文';
					const cover = post.data.heroImage || categoryCover[cat] || CoverEssay;
					return (
						<a class="item" href={`${base}blog/${post.id}/`}>
							<div class="cover">
								<Image src={cover} alt={post.data.title} width={960} height={540} />
								<div class="overlay"><span class="badge">{cat}</span></div>
							</div>
							<div class="content">
								<div class="topline">
									<p class="meta"><FormattedDate date={post.data.pubDate} /></p>
								</div>
								<h2 class="title">{post.data.title}</h2>
								<p class="excerpt">{post.data.description || '阅读这篇文章'}</p>
							</div>
						</a>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>
