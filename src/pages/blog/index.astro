---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1040px, calc(100% - 1rem));
			}
			.head {
				display: flex;
				justify-content: space-between;
				align-items: end;
				gap: 1rem;
				margin-bottom: 1rem;
			}
			.hint {
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.85rem;
			}
			.item {
				display: block;
				padding: 1rem 1rem 0.95rem;
				border: 1px solid rgba(var(--gray), 0.18);
				border-radius: 14px;
				text-decoration: none;
				background: linear-gradient(180deg, #fff 0%, #fcfcff 100%);
				transition: 0.18s ease;
			}
			.item:hover {
				transform: translateY(-2px);
				box-shadow: 0 12px 24px rgba(17, 24, 39, 0.08);
				border-color: rgba(var(--accent-rgb), 0.45);
			}
			.title {
				margin: 0 0 0.35rem;
				color: rgb(var(--black));
				font-size: 1.08rem;
				line-height: 1.45;
			}
			.excerpt {
				margin: 0 0 0.65rem;
				font-size: 0.92rem;
				color: rgb(var(--gray-dark));
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.meta {
				font-size: 0.84rem;
				color: rgb(var(--gray));
			}
			@media (max-width: 820px) {
				.list {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="head">
				<h1>文章</h1>
				<p class="hint">共 {posts.length} 篇</p>
			</div>
			<div class="list">
				{
					posts.map((post) => (
						<a class="item" href={`${base}blog/${post.id}/`}>
							<h2 class="title">{post.data.title}</h2>
							<p class="excerpt">{post.data.description || '阅读这篇文章'}</p>
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
						</a>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
