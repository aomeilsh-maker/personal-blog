---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = await getCollection('blog');
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const groups = posts.reduce((acc, p) => {
	const key = p.data.category || '未分类';
	(acc[key] ||= []).push(p);
	return acc;
}, {} as Record<string, typeof posts>);

const sorted = Object.entries(groups).sort((a, b) => b[1].length - a[1].length);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`分类 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main { width:min(1040px, calc(100% - 1rem)); }
			.group { margin-bottom: 1.2rem; padding: .9rem 1rem; border:1px solid rgba(var(--gray), .2); border-radius: 14px; }
			h2 { display:flex; justify-content:space-between; align-items:center; font-size:1.1rem; }
			.count { font-size:.85rem; color:rgb(var(--gray)); }
			ul { margin:.6rem 0 0; padding-left:1.1rem; }
			li { margin:.25rem 0; }
			a { text-decoration:none; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>文章分类</h1>
			{sorted.map(([name, list]) => (
				<section class="group" id={encodeURIComponent(name)}>
					<h2>{name}<span class="count">{list.length} 篇</span></h2>
					<ul>
						{list
							.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
							.map((post) => <li><a href={`${base}blog/${post.id}/`}>{post.data.title}</a></li>)}
					</ul>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>
