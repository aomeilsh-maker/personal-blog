---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import CoverJP from '../assets/category-covers/japanese.jpg';
import CoverAI from '../assets/category-covers/ai.jpg';
import CoverEssay from '../assets/category-covers/essay.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = await getCollection('blog', ({ data }) => !data.hidden);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const fixedCategories = ['日语学习', 'AI学习', '杂文'];
const groups = posts.reduce((acc, p) => {
	const key = fixedCategories.includes(p.data.category || '') ? (p.data.category as string) : '杂文';
	(acc[key] ||= []).push(p);
	return acc;
}, {} as Record<string, typeof posts>);

const sorted = fixedCategories.map((name) => [name, groups[name] || []] as const);
const coverMap: Record<string, any> = {
	日语学习: CoverJP,
	AI学习: CoverAI,
	杂文: CoverEssay,
};
const categorySlug: Record<string, string> = {
	日语学习: 'japanese',
	AI学习: 'ai',
	杂文: 'essay',
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`分类 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main { width:min(1120px, calc(100% - 1rem)); }
			.grid { display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 1rem; }
			.group {
				overflow:hidden;
				border:1px solid rgba(var(--gray), .2);
				border-radius: 16px;
				background:#fff;
			}
			.cover { position:relative; height: 148px; }
			.cover :global(img) { width:100%; height:100%; object-fit:cover; }
			.shade {
				position:absolute; inset:0;
				background: linear-gradient(to top, rgba(8,9,20,.6), rgba(8,9,20,.08));
				display:flex; align-items:flex-end; justify-content:space-between;
				padding: .65rem .8rem;
				color:#fff;
			}
			.name { font-size: 1rem; font-weight: 700; }
			.count { font-size:.82rem; opacity:.92; }
			.content { padding: .9rem .9rem 1rem; }
			.desc { margin:0 0 .85rem; font-size:.9rem; color:rgb(var(--gray)); }
			a { text-decoration:none; color: rgb(var(--black)); }
			a:hover { color: var(--accent); }
			.enter {
				display:inline-flex; align-items:center; justify-content:center;
				padding:.45rem .75rem; border-radius:10px;
				border:1px solid rgba(var(--gray), .25);
				font-size:.86rem; color:var(--accent);
			}
			@media (max-width:980px){ .grid{ grid-template-columns:1fr; } }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>文章分类</h1>
			<div class="grid">
				{sorted.map(([name, list]) => (
					<section class="group" id={encodeURIComponent(name)}>
						<div class="cover">
							<Image src={coverMap[name]} alt={name} width={1200} height={675} />
							<div class="shade">
								<span class="name">{name}</span>
								<span class="count">{list.length} 篇</span>
							</div>
						</div>
						<div class="content">
							<p class="desc">查看这个分类下的全部文章。</p>
							<a class="enter" href={`${base}categories/${categorySlug[name]}/`}>进入分类</a>
						</div>
					</section>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
